<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>3atour & Travel · Privacy & Terms</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      background: #fafafa;
      color: #1e1e2f;
      line-height: 1.6;
      padding: 2rem 1rem;
    }

    .container {
      max-width: 960px;
      margin: 0 auto;
      background: white;
      border-radius: 2rem;
      box-shadow: 0 20px 40px -12px rgba(0, 20, 30, 0.2);
      overflow: hidden;
      border: 1px solid #e9eef2;
    }

    header {
      background: linear-gradient(145deg, #003057, #001f3f);
      color: white;
      padding: 2.5rem 2rem;
      text-align: center;
    }

    header h1 {
      font-size: 2.4rem;
      font-weight: 600;
      letter-spacing: -0.5px;
      margin-bottom: 0.25rem;
    }

    header h1 span {
      color: #ffd966;
      font-weight: 300;
    }

    header .subhead {
      font-size: 1rem;
      opacity: 0.85;
      border-bottom: 1px dashed rgba(255,255,255,0.3);
      padding-bottom: 1rem;
      max-width: 500px;
      margin: 0.5rem auto 0;
    }

    .last-updated {
      background: #f0f6fb;
      padding: 0.8rem 2rem;
      font-size: 0.9rem;
      text-align: right;
      color: #2c3e50;
      border-bottom: 1px solid #dde5ec;
    }

    .last-updated strong {
      font-weight: 600;
      color: #001f3f;
    }

